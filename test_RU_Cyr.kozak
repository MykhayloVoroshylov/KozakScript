// Test 3
counter := 0;
Попробуй {
    counter := counter + 1;
    Печатать("In try block, counter: ", counter);
    Бросать("Custom error message!"); // Kydaty
} Поймать(e){
    counter := counter + 1;
    Печатать("In catch block, counter:", counter);
    Печатать("Error", e);
} Наконец { // Vkintsi
    counter := counter + 1;
    Печатать("In finally block, counter:", counter);
    Печатать("This always runs!");
}
Печатать("Final counter:", counter);

