        Печатать("Inner catch:", e);
        Бросать("Re-throwing from inner catch");
    }
    
} Поймать(e) {
    Печатать("Outer catch:", e);
}

// Test 5
Задание safeDivide(a, b) {
    Попробуй {
        Если(b == 0) {
            Бросать("Cannot divide by zero, kozache!");
        }
        Вернуть a / b;
    } Поймать(e) {
        Печатать("Division error:", e);
        Вернуть 0;
    }
}

result1 := safeDivide(10, 2);
Печатать("10 / 2 =", result1);

result2 := safeDivide(10, 0);
Печатать("10 / 0 =", result2);

