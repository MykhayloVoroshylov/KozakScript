// Polymorphism and Inheritance
Класс Parent {
    Творение() {
        этот.field1 := "Parent field";
    }
    Задание GetField1() {
        Печатать("Parent method called!");
        Вернуть этот.field1;
    }
}

Класс Child : Parent {
    Задание GetField2() {
        Вернуть "Child field";
    }
}

my_object := новый Child();
// These two lines are now simple statements that should require semicolons:
Печатать(my_object.GetField1());
// Line 20 - Test inheritance (should print Parent method called! Parent field)
Печатать(my_object.GetField2());
// Line 21 - Test polymorphism (should print Child field)

