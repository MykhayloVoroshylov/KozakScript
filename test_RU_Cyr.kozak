Печатать("Flattened:", flat);

Задание matrix_add(a, b) {
    rows := размер_матрицы(a)[0];
    cols := размер_матрицы(a)[1];
    result := создать_матрицу(rows, cols, 0);
    
    Для (i := 0; i < rows; i++) {
        Для (j := 0; j < cols; j++) {
            result[i][j] := a[i][j] + b[i][j];
        }
    }
    
    Вернуть result;
}

Задание matrix_multiply_scalar(mat, scalar) {
    rows := размер_матрицы(mat)[0];
    cols := размер_матрицы(mat)[1];
    result := создать_матрицу(rows, cols, 0);
    
    Для (i := 0; i < rows; i++) {
        Для (j := 0; j < cols; j++) {
            result[i][j] := mat[i][j] * scalar;
        }
    }
    
    Вернуть result;
}

m1 := [[1, 2], [3, 4]];
m2 := [[5, 6], [7, 8]];

sum := matrix_add(m1, m2);
Печатать("Sum:", sum);

doubled := matrix_multiply_scalar(m1, 2);
Печатать("Doubled:", doubled);
