//Поліморфізм та наслідування
Клас Parent {
    Твір() {
        цей.field1 := "Parent field";
    }
    Завдання GetField1() {
        Співати("Parent method called!");
        Повернути цей.field1;
    }
}

Клас Child : Parent {
    Завдання GetField2() {
        Повернути "Child field";
    }
}

my_object := новий Child();
// These two lines are now simple statements that should require semicolons:
Співати(my_object.GetField1()); 
Співати(my_object.GetField2()); 



