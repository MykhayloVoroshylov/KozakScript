// Test 3
counter := 0;

Спробуй {
    counter := counter + 1;
    Співати("In try block, counter: ", counter);
    Кидати("Custom error message!");
} Піймати(e){
    counter := counter + 1;
    Співати("In catch block, counter:", counter);
    Співати("Error", e);
} Вкінці{
    counter := counter + 1;
    Співати("In finally block, counter:", counter);
    Співати("This always runs!");
}
Співати("Final counter:", counter);

