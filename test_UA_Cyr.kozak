        Співати("Inner try");
        Кидати("Inner error");
    } Піймати(e) {
        Співати("Inner catch:", e);
        Кидати("Re-throwing from inner catch");
    }
    
} Піймати(e) {
    Співати("Outer catch:", e);
}

// Test 5
Завдання safeDivide(a, b) {
    Спробуй {
        Якщо(b == 0) {
            Кидати("Cannot divide by zero, kozache!");
        }
        Повернути a / b;
    } Піймати(e) {
        Співати("Division error:", e);
        Повернути 0;
    }
}

result1 := safeDivide(10, 2);
Співати("10 / 2 =", result1);

result2 := safeDivide(10, 0);
Співати("10 / 0 =", result2);

