// Test 7
Завдання safeArrayAccess(arr, index) {
    Спробуй {
        Повернути arr[index];
    } Піймати(e) {
        Співати("Array access error:", e);
    } Вкінці {
        Співати("Array access attempted");
    }
}

my_arr := [10, 20, 30];
val1 := safeArrayAccess(my_arr, 1);
Співати("Value at index 1:", val1);

val2 := safeArrayAccess(my_arr, 10);
Співати("Value at index 10:", val2);

arr23 := [[1,2,3],[4,5,6]];
Співати(arr23[1][2]);

arr23[0][0] := 100;
